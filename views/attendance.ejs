<!DOCTYPE html>
<html>
<head><title>Attendance</title><link rel="stylesheet" href="/style.css"></head>
<body>
    <nav><a href="/">Back</a></nav>
    <div class="container">
        <h2>Mark Attendance</h2>
        <form action="/attendance" method="POST" class="card">
            <select name="studentId" required>
                <option value="">Select Student</option>
                <% students.forEach(s => { %>
                    <option value="<%= s.id %>"><%= s.name %></option>
                <% }) %>
            </select>
            <select name="status">
                <option value="Present">Present</option>
                <option value="Absent">Absent</option>
                <option value="Late">Late</option>
            </select>
            <input type="date" name="date" required>
            <button type="submit">Save Attendance</button>
        </form>
        <div class="card">
            <h3>Recent Records</h3>
            <table>
                <tr><th>Date</th><th>Student ID</th><th>Status</th></tr>
                <% records.slice(-5).reverse().forEach(r => { %>
                    <tr><td><%= r.date %></td><td><%= r.studentId %></td><td><%= r.status %></td></tr>
                <% }) %>
            </table>
        </div>
    </div>
</body>
</html>